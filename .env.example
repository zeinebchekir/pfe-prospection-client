# ═══════════════════════════════════════════════════════════════════════════════
#  QUALIFIXPROJECT — Environment Template
# ═══════════════════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in the values marked with "change-me".
#  This single .env file controls ALL services in the project.
#
#  cp .env.example .env
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Django Backend ────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web
CSRF_TRUSTED_ORIGINS=http://localhost:5174,http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:5174
COOKIE_SECURE=False

# ── Django Database (Postgres 15) ─────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=crmpfe_db
DB_USER=crmpfe_user
DB_PASSWORD=crmpfe_password
DB_HOST=db
DB_PORT=5432

# ── PgAdmin (single instance, manages both databases) ────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# ── Airflow / ETL ─────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./ETL_service
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres-airflow/airflow
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres-airflow/airflow
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
AIRFLOW__CORE__FERNET_KEY=change-me-generate-with-python-fernet
AIRFLOW__API_AUTH__JWT_SECRET=change-me-random-jwt-secret
AIRFLOW__API_AUTH__JWT_ISSUER=airflow
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
_PIP_ADDITIONAL_REQUIREMENTS=

# ── Airflow Postgres (separate from Django DB) ────────────────────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow

# ── ETL FastAPI ───────────────────────────────────────────────────────────────
ETL_DATABASE_URL=postgresql://airflow:airflow@postgres-airflow/airflow
GEMINI_API_KEY=
INSEE_TOKEN=

# ── IA-ML Service ─────────────────────────────────────────────────────────────
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:4b
ETL_SERVICE_URL=http://etl-fastapi:8000
GROQ_API_KEY=
APIFY_TOKEN=
SERPER_API_KEY=

# ── Frontend (Vue.js) ─────────────────────────────────────────────────────────
VITE_PROXY_TARGET=http://web:8000
VITE_ETL_API_URL=http://localhost:8001
